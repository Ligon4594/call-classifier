# C&R Services Call Classification App — environment variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# ---- Anthropic (classification engine) ----
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- ServiceTitan (call source + write-back) ----
# Tenant ID is already known. The other 3 require dev portal access.
# Status as of 2026-04-09: requested integration env access, waiting on response.
SERVICETITAN_TENANT_ID=4029621142
SERVICETITAN_APP_KEY=
SERVICETITAN_CLIENT_ID=
SERVICETITAN_CLIENT_SECRET=

# ---- Dialpad (transcript + recap source) ----
# Get one at: https://dialpad.com/app/admin/api-keys
DIALPAD_API_KEY=

# ---- Email reporter (weekly summary) ----
# SMTP provider TBD — pick one of SendGrid / Resend / Postmark
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
REPORT_RECIPIENT=tligon@crhvacpro.com
